# Copy to .env and adjust. The real .env is gitignored (contains receiver IP/coords).
TZ=Europe/Rome
RECEIVER_NAME=My ADS-B
RECEIVER_LAT=45.0000
RECEIVER_LON=9.0000

# Remote receiver Beast output (RTL-SDR Raspberry Pi)
RASPBERRY_BEAST_HOST=192.168.1.x
RASPBERRY_BEAST_PORT=30005

# Logger
ADSB_SOURCE_URL=http://tar1090/data/aircraft.json
POLL_SECONDS=5
SAMPLE_MIN_SECONDS=60
DB_PATH=/data/adsb.sqlite
WEB_BIND=0.0.0.0
WEB_PORT=8080

# Enrichment (external lookups for type/operator/route/photo). Set false to go offline.
ENRICH_ENABLED=true
# MILITARY_CALLSIGN_PREFIXES=IAM,ITAF,AMI,NATO,RRR,RCH,GAF,FAF
# HEMS_MARKERS=ELILOMBARDA,BABCOCK,HEMS,AMBULANZA,ELISOCCORSO,118
